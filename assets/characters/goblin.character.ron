// Goblin enemy template — parity with the Godot `goblin_stats.tres`, which
// omits Attack; here every field is explicit (attack matches the old default).
(
    display_name: "Goblin",
    sprite: "sprites/enemy.png",
    stats: (
        max_health: 80,
        attack: 10,
        defense: 4,
    ),
    damage_variance: (
        min: 0.8,
        max: 1.2,
    ),
)
